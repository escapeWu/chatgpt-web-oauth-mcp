CHATGPT_MCP_HOST=127.0.0.1
CHATGPT_MCP_PORT=8766
CHATGPT_MCP_WORKSPACE_ROOT=/absolute/path/to/workspace
CHATGPT_MCP_STATE_DIR=~/.chatgpt-web-oauth-mcp
CHATGPT_MCP_AUTH_TOKEN=replace-me
# For ChatGPT web OAuth mode:
# CHATGPT_MCP_AUTH_MODE=oauth
# CHATGPT_MCP_PUBLIC_BASE_URL=https://your-public-mcp-host.example
# CHATGPT_MCP_OAUTH_LOGIN_TOKEN=
# CHATGPT_MCP_OAUTH_SCOPES=local-ops
# Add obsidian to scopes only when CHATGPT_MCP_ENABLE_OBSIDIAN=1.
# CHATGPT_MCP_OAUTH_TOKEN_TTL_SECONDS=86400
CHATGPT_MCP_CLOUDFLARED_CONFIG=
CHATGPT_MCP_TUNNEL_NAME=
# Set to 1 when an existing cloudflared service already maps your public host to this MCP server.
CHATGPT_MCP_EXTERNAL_CLOUDFLARED=0
CHATGPT_MCP_CODEX_COMMAND=codex
CHATGPT_MCP_CLAUDE_COMMAND=claude
CHATGPT_MCP_COMMAND_TIMEOUT=120
CHATGPT_MCP_DELEGATE_TIMEOUT=1800
CHATGPT_MCP_DEBUG_MCP_LOGGING=0
CHATGPT_MCP_GRACEFUL_SHUTDOWN_SECONDS=30
CHATGPT_MCP_WATCHDOG_INTERVAL_SECONDS=60
CHATGPT_MCP_DOCTOR_FAILURE_THRESHOLD=3
CHATGPT_MCP_DOCTOR_BASE_BACKOFF_SECONDS=300
CHATGPT_MCP_DOCTOR_MAX_BACKOFF_SECONDS=3600
CHATGPT_MCP_LAUNCHD_LABEL_PREFIX=com.chatgpt-web-oauth-mcp

# Optional Obsidian Local REST API native MCP proxy. Disabled by default; only set to 1 after the user explicitly opts in.
# When enabled, this bridge registers obsidian_* tools that proxy to the plugin's native MCP tools.
CHATGPT_MCP_ENABLE_OBSIDIAN=0
# Enable the Obsidian Local REST API plugin and paste its API key here.
# The plugin's native MCP endpoint is usually https://127.0.0.1:27124/mcp/ (or http://127.0.0.1:27123/mcp/ if HTTP is enabled).
OBSIDIAN_API_KEY=
OBSIDIAN_MCP_URL=https://127.0.0.1:27124/mcp/
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124
OBSIDIAN_PROTOCOL=https
OBSIDIAN_VERIFY_SSL=0
OBSIDIAN_TIMEOUT_SECONDS=10

# Optional NotebookLM support. Disabled by default; only set to 1 after the user explicitly opts in.
# Requires installing the optional dependency: pip install -e ".[notebooklm]"
CHATGPT_MCP_ENABLE_NOTEBOOKLM=0
# Auth can be loaded from notebooklm-py's default active profile, an explicit profile, or a storage_state.json file.
NOTEBOOKLM_PROFILE=
NOTEBOOKLM_STORAGE_PATH=
# Optional default notebook id used by NotebookLM tools when notebook_id is omitted.
CHATGPT_MCP_NOTEBOOKLM_DEFAULT_NOTEBOOK_ID=
# NOTEBOOKLM_NOTEBOOK is also accepted as a fallback default notebook id for compatibility with notebooklm-py CLI.
NOTEBOOKLM_NOTEBOOK=
NOTEBOOKLM_TIMEOUT_SECONDS=30

# Optional live NotebookLM E2E tests. Disabled by default and never needed for the normal test suite.
# Enable only in a local environment with notebooklm-py installed and a valid NotebookLM session.
NOTEBOOKLM_E2E=0
# Optional pre-existing notebook for source/chat E2E. If omitted, source/chat
# is skipped unless temp creation is allowed.
NOTEBOOKLM_E2E_NOTEBOOK_ID=
# Allow the E2E test to create a temporary notebook. The test deletes it only
# when notebooklm-py exposes notebooks.delete.
NOTEBOOKLM_E2E_CREATE_TEMP=0
